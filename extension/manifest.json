{
  "manifest_version": 3,
  "name": "Task List — Quick Add & Notes",
  "version": "1.0.0",
  "description": "Add tasks and jot notes to your Task List from a popup, and open the app as a tab when Chrome starts.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Task List — Quick Add",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "background": { "service_worker": "background.js" },
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:4000/*"],
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
